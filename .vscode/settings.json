{
  "files.watcherExclude": {
    "**/energi.world/**": true,
    "**/github.com/**": true,
    "**/gopkg.in/**": true,
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/microhttp/www/**": true,
  },
  "eslint.options": {
    "ecmaVersion": 9,
    "max-len": [
      {
        "code": 450,
        "tabWidth": 2,
        "ignoreUrls": true
      }
    ],
    "ecmaFeatures": {
      "modules": true,
      "spread" : true,
      "restParams" : true
    },
  },
  "eslint.format.enable": true,
  "eslint.validate": [
    "svelte",
    "javascript",
    "css",
  ],
  "eslint.probe": [
    "svelte",
    "javascript",
    "css",
  ],
  "eslint.codeAction.showDocumentation": {
    "enable": true
  }
}
